#!/usr/bin/env node

var program = require('commander').program;
var utils = require('../lib/utils');

var logging = require('@tryghost/logging');
var knexMigrator;

utils.getKnexMigrator({path: process.cwd()})
    .then(function (KnexMigrator) {
        program
            .option('--v <item>')
            .option('--only <item>')
            .option('--mgpath <path>')
            .option('--force')
            .option('--init')
            .parse(process.argv);

        var options = program.opts();

        try {
            knexMigrator = new KnexMigrator({knexMigratorFilePath: options.mgpath, executedFromShell: true});
        } catch (err) {
            logging.error(err);
            process.exit(1);
        }

        return knexMigrator.migrate({
            version: options.v,
            only: options.only,
            force: options.force,
            init: options.init
        }).then(function () {
            logging.info('Finished database migration!');
        });
    })
    .catch(function (err) {
        logging.error(err);
        process.exit(1);
    });
